{
  "name": "mitake",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:local": "node scripts/local-server.mjs",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build:inline": "tsc --noEmit false --outDir dist --rootDir src --module ES2022 --target ES2022 && node scripts/build-inline-worker.mjs",
    "deploy:api": "pnpm run build:inline && node scripts/deploy-cloudflare-api.mjs",
    "check": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260614.0",
    "typescript": "^5.8.3",
    "wrangler": "^4.61.1"
  }
}
